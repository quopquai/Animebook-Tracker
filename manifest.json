{
  "manifest_version": 3,
  "name": "Animebook Time Tracker",
  "version": "4.6",
  "description": "Track watch time for Animebook, asbplayer, YouTube, cijapanese, TVer, Disney+ and Amazon Prime videos",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://animebook.github.io/*",
        "file:///Users/julisco/Documents/Animebook*.html*"
      ],
      "js": [
        "content.js"
      ]
    },
    {
      "matches": [
        "https://app.asbplayer.dev/*",
        "https://killergerbah.github.io/asbplayer/*"
      ],
      "js": [
        "asbplayer.js"
      ]
    },
    {
      "matches": [
        "https://cijapanese.com/*"
      ],
      "js": [
        "cijapanese.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://animebook.github.io/*",
    "file:///Users/julisco/Documents/Animebook*.html*",
    "https://www.youtube.com/*",
    "https://app.asbplayer.dev/*",
    "https://killergerbah.github.io/asbplayer/*",
    "https://cijapanese.com/*",
    "https://tver.jp/*",
    "https://www.disneyplus.com/*",
    "https://disneyplus.com/*",
    "https://www.amazon.com/*",
    "https://www.amazon.co.jp/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.de/*",
    "https://www.amazon.fr/*",
    "https://www.amazon.it/*",
    "https://www.amazon.es/*",
    "https://www.amazon.ca/*",
    "https://www.amazon.com.au/*",
    "https://www.amazon.com.br/*",
    "https://www.amazon.com.mx/*",
    "https://www.amazon.nl/*",
    "https://www.amazon.pl/*",
    "https://www.amazon.se/*"
  ]
}